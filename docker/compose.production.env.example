# ─────────────────────────────────────────────────────────────────────────────
# Production stack — environment variables example
# Copy to .env, fill in the values, and run: docker compose -f compose.production.yml up -d
# ─────────────────────────────────────────────────────────────────────────────

# General
TZ=America/Sao_Paulo
ORGANIZATION_NAME=My Organization

# Domains
CRM_FRONTEND_URL=https://crm.example.com
CRM_API_URL=https://crm-api.example.com
EVOLUTION_SERVER_URL=https://evo.example.com
N8N_WEBHOOK_URL=https://bpa.example.com
NEXUS_URL=https://nexus.example.com

# CRM Database (pgvector/pgvector:pg16)
CRM_POSTGRES_HOST=crm_postgres
CRM_POSTGRES_PORT=5432
CRM_POSTGRES_DB=evo_community
CRM_POSTGRES_USER=evo_crm
CRM_POSTGRES_PASSWORD=change_me
CRM_POSTGRES_SSLMODE=disable

# CRM Redis
CRM_REDIS_PASSWORD=change_me
CRM_REDIS_URL=redis://:change_me@crm_redis:6379/0

# Rails secrets
SECRET_KEY_BASE=change_me_64_chars_min
JWT_SECRET_KEY=change_me_64_chars_min
DOORKEEPER_JWT_SECRET_KEY=change_me_64_chars_min
EVOAI_CRM_API_TOKEN=change_me

# Encryption (used by evo_core and evo_processor)
ENCRYPTION_KEY=change_me_base64_32_bytes

# SMTP
MAILER_SENDER_EMAIL=noreply@example.com
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=change_me
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# Meta / Instagram
FB_APP_ID=change_me
FB_APP_SECRET=change_me
IG_VERIFY_TOKEN=change_me

# Bot Runtime
BOT_RUNTIME_SECRET=change_me

# MFA
MFA_ISSUER=MyOrganization

# EvoNexus (knowledge service API key)
NEXUS_API_KEY=change_me

# ─────────────────────────────────────────────────────────────────────────────
# Evolution API
# ─────────────────────────────────────────────────────────────────────────────
EVOLUTION_POSTGRES_DB=evolution
EVOLUTION_POSTGRES_USER=evolution
EVOLUTION_POSTGRES_PASSWORD=change_me
EVOLUTION_REDIS_PASSWORD=change_me
AUTHENTICATION_API_KEY=change_me
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true
CONFIG_SESSION_PHONE_CLIENT=MyOrg
CONFIG_SESSION_PHONE_NAME=MyOrg
QRCODE_LIMIT=30
LOG_LEVEL=ERROR,WARN,INFO
LANGUAGE=pt-BR
TELEMETRY=false
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:change_me@evolution_postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=evolution_crm
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:change_me@evolution_redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=false
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true

# ─────────────────────────────────────────────────────────────────────────────
# n8n
# ─────────────────────────────────────────────────────────────────────────────
N8N_POSTGRES_DB=n8n
N8N_POSTGRES_USER=n8n
N8N_POSTGRES_PASSWORD=change_me
N8N_ENCRYPTION_KEY=change_me
N8N_USER_MANAGEMENT_JWT_SECRET=change_me
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_HOST=bpa.example.com
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
N8N_HIRING_BANNER_ENABLED=false
N8N_SECURE_COOKIE=true
N8N_PROXY_HOPS=1
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
GENERIC_TIMEZONE=America/Sao_Paulo
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=change_me

# ─────────────────────────────────────────────────────────────────────────────
# GHCR credentials (for ghcr.io/tetrabi/evo-ai-crm-community private image)
# Configure in Dokploy UI → Registry → GitHub Container Registry
# or run: docker login ghcr.io -u <github-user> -p <ghcr-token>
# ─────────────────────────────────────────────────────────────────────────────
# GHCR_TOKEN=ghp_...
